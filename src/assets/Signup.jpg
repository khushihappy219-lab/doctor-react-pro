    #didomi-host {
      font-family: Interface, sans-serif;
    }
    #didomi-host a:not(.didomi-no-link-style) {
      text-decoration: underline;
      color: #00CCFF !important;
    }
    #didomi-host a:not(.didomi-no-link-style):hover {
      opacity: 0.7 !important;
    }
